# Write your MySQL query statement below
with tmp as (
    select student_id, max(grade) as max_grade
    from enrollments
    group by student_id
)
select e.student_id, min(course_id) as course_id, grade 
from Enrollments e
JOIN tmp ON e.student_id = tmp.student_id 
     AND e.grade = tmp.max_grade
group by student_id
order by student_id asc